//@version=6
strategy("BASEBOT+VDELTA)", overlay=true, default_qty_type=strategy.cash, default_qty_value=1000)

// === Input Settings ===
kLength = input.int(14, title="StochRSI K Length")
dLength = input.int(3, title="StochRSI D Length")
smoothK = input.int(3, title="StochRSI Smooth K")
rsiLength = input.int(14, title="RSI Length")
rsiMALength = input.int(14, title="RSI MA Length")
macdFast = input.int(12, title="MACD Fast Length")
macdSlow = input.int(26, title="MACD Slow Length")
macdSignal = input.int(9, title="MACD Signal Length")
volLength = input.int(20, title="Volume MA Length")
atrLength = input.int(14, title="ATR Length")
atrMultiplier = input.float(1.0, title="ATR Sensitivity")

// === Toggle Settings ===
showATRLabels = input.bool(true, title="Show ATR Font Labels")
showDeltaLabels = input.bool(true, title="Show Volume Delta Font Labels")

// === Indicator Calculations ===
k = ta.sma(ta.stoch(close, high, low, kLength), smoothK)
d = ta.sma(k, dLength)
bullCrossStoch = ta.crossover(k, d)
bearCrossStoch = ta.crossunder(k, d)

rsi = ta.rsi(close, rsiLength)
rsiMA = ta.sma(rsi, rsiMALength)
rsiCrossUp = ta.crossover(rsi, rsiMA)
rsiCrossDown = ta.crossunder(rsi, rsiMA)

[macdLine, macdSignalLine, _] = ta.macd(close, macdFast, macdSlow, macdSignal)
macdHist = macdLine - macdSignalLine
macdLightRed = macdHist > macdHist[1]
macdLightGreen = macdHist < macdHist[1]

volMA = ta.sma(volume, volLength)
volSpike = volume > volMA

atr = ta.atr(atrLength)
atrFilter = atr > atrMultiplier * ta.sma(atr, atrLength)

// === Simulated Volume Delta ===
delta = volume * (close - open) / math.max((high - low), syminfo.mintick)

// === Strategy Logic (now includes Volume Delta) ===
longCondition = bullCrossStoch and (math.abs(macdLine - macdSignalLine) < 0.005 or macdLightRed) and rsiCrossUp and volSpike and delta > 0
smartShortCondition = bearCrossStoch and (k[1] > 80) and (rsi[1] > 50) and macdLightGreen and volSpike and delta < 0

// === Execute Core Trades ===
if (longCondition)
    strategy.entry("Long", strategy.long)
    label.new(bar_index, low, text="L", color=color.rgb(41, 172, 46, 44), style=label.style_label_up, textcolor=color.white, size=size.small)

if (smartShortCondition)
    strategy.entry("Short", strategy.short)
    label.new(bar_index, high, text="S", color=color.rgb(255, 82, 82, 28), style=label.style_label_down, textcolor=color.white, size=size.small)

// === ATR Font-Only Tags ===
atrLongY = low - (atr * 2)
atrShortY = high + (atr * 2)

if (showATRLabels and longCondition and atrFilter)
    label.new(bar_index, atrLongY, text="LATR", color=color.rgb(37, 171, 70, 18), textcolor=color.white, style=label.style_label_up, size=size.small)

if (showATRLabels and smartShortCondition and atrFilter)
    label.new(bar_index, atrShortY, text="SATR", color=color.rgb(204, 69, 69, 22), textcolor=color.white, style=label.style_label_down, size=size.small)

// === Volume Delta Font Tags ===
if (showDeltaLabels and longCondition)
    label.new(bar_index, low - atr, text="LVD", color=color.rgb(11, 127, 58), textcolor=color.white, style=label.style_label_up, size=size.small)

if (showDeltaLabels and smartShortCondition)
    label.new(bar_index, high + atr, text="SVD", color=color.rgb(171, 36, 36), textcolor=color.white, style=label.style_label_down, size=size.small)
